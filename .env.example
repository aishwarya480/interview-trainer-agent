# ============================================================
#  IBM watsonx.ai — Interview Trainer Agent
#  Copy this file to .env and fill in your real values.
#  NEVER commit the real .env to version control.
# ============================================================

# --- IBM Cloud Credentials -----------------------------------
IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai API endpoint (region-specific)
# US South : https://us-south.ml.cloud.ibm.com
# EU-DE    : https://eu-de.ml.cloud.ibm.com
# AU-SYD   : https://au-syd.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Flask Settings ------------------------------------------
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
FLASK_ENV=development
FLASK_DEBUG=true

# --- File Upload Settings ------------------------------------
MAX_CONTENT_LENGTH=16777216   # 16 MB in bytes
UPLOAD_FOLDER=uploads
REPORTS_FOLDER=reports

# --- Agent Behaviour (override AGENT_INSTRUCTIONS defaults) --
# Options: easy | medium | hard
INTERVIEW_DIFFICULTY=medium
# Comma-separated: hr,technical,behavioral,situational
QUESTION_CATEGORIES=hr,technical,behavioral
# Number of questions to generate per session
NUM_QUESTIONS=8
# Options: encouraging | balanced | strict
FEEDBACK_STYLE=balanced
